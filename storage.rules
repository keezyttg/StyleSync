rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Closet item photos — owner writes; any signed-in user reads
    // (outfit posts embed closet image URLs, so the feed needs cross-user read)
    match /closet/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Outfit photos — owner writes; any signed-in user reads
    match /outfits/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Profile / avatar photos — owner writes; any signed-in user reads
    match /avatars/{userId}/{allPaths=**} {
      allow read:  if request.auth != null;
      allow write: if request.auth.uid == userId;
    }

    // Deny everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
