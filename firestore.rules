rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── User profiles ──────────────────────────────────────────────────────────
    // Any signed-in user can read profiles (needed for feed, search, user pages).
    // Only the owner can create/update their own doc.
    match /users/{uid} {
      allow read:   if request.auth != null;
      allow create: if request.auth.uid == uid;
      allow update: if request.auth.uid == uid;
      allow delete: if false;

      // Closet — fully private to owner
      match /closet/{itemId} {
        allow read, write: if request.auth.uid == uid;
      }

      // Saved outfits — private to owner
      match /saved/{saveId} {
        allow read, write: if request.auth.uid == uid;
      }

      // Following list — owner manages who they follow
      match /following/{targetUid} {
        allow read:  if request.auth.uid == uid;
        allow write: if request.auth.uid == uid;
      }

      // Followers list — owner reads; the actual follower writes their own entry
      // followUser() does: setDoc(users/{targetUid}/followers/{currentUid}, ...)
      match /followers/{followerUid} {
        allow read:  if request.auth.uid == uid;
        allow write: if request.auth.uid == followerUid;
      }

      // Notifications — owner reads/updates/deletes; any auth user can create
      // (follow, rating, and save events write to the recipient's subcollection)
      match /notifications/{notifId} {
        allow read, update, delete: if request.auth.uid == uid;
        allow create: if request.auth != null;
      }
    }

    // ── Outfits ────────────────────────────────────────────────────────────────
    match /outfits/{outfitId} {
      allow read: if request.auth != null;

      // Creator must match the userId field they write
      allow create: if request.auth != null
                    && request.resource.data.userId == request.auth.uid;

      // Owner can update anything.
      // Other signed-in users can only touch aggregate counters
      // (ratingTotal / ratingCount / avgRating from rateOutfit, saves from saveOutfit).
      allow update: if request.auth.uid == resource.data.userId
                    || (request.auth != null
                        && request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly(['ratingTotal', 'ratingCount', 'avgRating', 'saves']));

      allow delete: if request.auth.uid == resource.data.userId;

      // Ratings — document ID is the rater's uid, enforcing one rating per user
      match /ratings/{ratingUserId} {
        allow read:  if request.auth != null;
        allow write: if request.auth.uid == ratingUserId;
      }
    }

    // ── Reports ───────────────────────────────────────────────────────────────
    // Write-only from the client. Reading/moderating happens in the Firebase console
    // or via an admin SDK — never exposed to the app.
    match /reports/{reportId} {
      allow create: if request.auth != null
                    && request.resource.data.reporterUid == request.auth.uid;
      allow read, update, delete: if false;
    }

    // ── Communities ────────────────────────────────────────────────────────────
    match /communities/{communityId} {
      allow read: if request.auth != null;

      allow create: if request.auth != null
                    && request.resource.data.createdBy == request.auth.uid;

      // Creator can update anything; others can only touch the counters
      // (memberCount via joinCommunity/leaveCommunity, postCount via createOutfit)
      allow update: if request.auth != null
                    && (request.auth.uid == resource.data.createdBy
                        || request.resource.data.diff(resource.data)
                             .affectedKeys()
                             .hasOnly(['memberCount', 'postCount']));

      allow delete: if request.auth.uid == resource.data.createdBy;

      // Membership docs — users manage their own membership
      match /members/{userId} {
        allow read:  if request.auth != null;
        allow write: if request.auth.uid == userId;
      }
    }
  }
}
